{
  "name": "ratbvscraper",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "bun --watch server/index.ts",
    "client:dev": "vite",
    "build": "vite build",
    "start": "bun run build && bun server/index.ts",
    "migrate": "bun scripts/migrate.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
